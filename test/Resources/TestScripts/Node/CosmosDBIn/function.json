{
  "bindings": [
    {
      "type": "queueTrigger",
      "name": "input",
      "queueName": "cosmosdb-input-node",
      "direction": "in"
    },
    {
      "type": "cosmosDB",
      "name": "itemIn",
      "direction": "in",
      "databaseName": "InOutItemDb",
      "containerName": "ItemCollection",
      "partitionKey": "{id}",
      "id": "{id}"
    },
    {
      "type": "cosmosDB",
      "name": "itemOut",
      "direction": "out",
      "databaseName": "InOutItemDb",
      "containerName": "ItemCollection",
      "createIfNotExists": true,
      "partitionKey": "{id}"
    }
  ]
}
